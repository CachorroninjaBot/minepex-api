# ─── minepex-api — variáveis de ambiente ─────────────────────────────
# Copie para .env e preencha. O .env NÃO deve ser commitado (já está no .gitignore).

# URL do site (CORS + redirect de volta após login)
ALLOWED_ORIGIN=https://site-minepex.vercel.app

# Segredo compartilhado com o plugin (deve bater com plugin-secret no website.yml)
PLUGIN_SECRET=minepex-plugin-secret

# URL pública do servidor Minecraft (onde o plugin expõe a Link API)
# Ex: http://SEU_IP_PUBLICO:8081  — deixe vazio para desabilitar a descoberta de MC
PLUGIN_LINK_URL=

# ─── Discord OAuth2 (login no site) ──────────────────────────────────
# Crie o app em https://discord.com/developers/applications
# Adicione o Redirect URI abaixo em "OAuth2 > Redirects".
DISCORD_CLIENT_ID=SEU_CLIENT_ID
DISCORD_CLIENT_SECRET=SEU_CLIENT_SECRET
DISCORD_REDIRECT_URI=https://minepex-api.onrender.com/api/auth/discord/callback

# Segredo para assinar o cookie de sessão (gere um valor aleatório forte)
SESSION_SECRET=gere-um-segredo-aleatorio-forte-aqui

# ─── PIX / Loja ─────────────────────────────────────────────────────
PIX_KEY=sua-chave-pix-aqui
ADMIN_KEY=minepex2026
